<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    tools:context=".AlertDetailsActivity">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@android:color/white">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:layout_centerVertical="true"
            app:tint="@android:color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert Details"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_toEndOf="@id/backButton"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@+id/bottomButtons"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Main Alert Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFF9E6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_warning"
                        app:tint="#F59E0B"
                        android:background="@drawable/circular_background_light_yellow"
                        android:padding="12dp" />

                    <TextView
                        android:id="@+id/alertTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="High Respiratory Rate"
                        android:textColor="#92400E"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:id="@+id/patientInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient: Jane Smith (ICU-02)"
                        android:textColor="#B45309"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/triggeredTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Triggered: 10:42 AM (15m ago)"
                        android:textColor="#D97706"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Parameter Context Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parameter Context"
                        android:textColor="@android:color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Current Value"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/currentValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="35 bpm"
                            android:textColor="#EF4444"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Limit Set"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/limitValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30 bpm"
                            android:textColor="@android:color/black"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <ProgressBar
                        android:id="@+id/parameterProgressBar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:progress="80"
                        android:progressDrawable="@drawable/red_progress_bar" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- AI Analysis Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Analysis"
                            android:textColor="@android:color/black"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:drawableStart="@drawable/ic_ai_star"
                            android:drawablePadding="8dp"
                            app:drawableTint="#8B5CF6" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VentGuard Neural v2.4"
                            android:textColor="#8B5CF6"
                            android:textSize="12sp"
                            android:background="@drawable/rounded_bg_light_purple"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Confidence"
                        android:textColor="@android:color/darker_gray"
                        android:layout_marginTop="16dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">
                        <ProgressBar
                            android:id="@+id/confidenceProgressBar"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:progress="87"
                            android:progressDrawable="@drawable/purple_progress_bar"
                            android:layout_centerVertical="true"
                            android:layout_toStartOf="@id/confidenceText"
                            android:layout_marginEnd="8dp" />
                        <TextView
                            android:id="@+id/confidenceText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="87%"
                            android:textColor="#8B5CF6"
                            android:textStyle="bold"
                            android:layout_alignParentEnd="true" />
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F9FAFB"
                        android:padding="16dp"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Probable Cause:"
                            android:textColor="#4B5563"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/probableCauseText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Patient agitation or pain likely causing tachypnea. Check sedation levels."
                            android:textColor="#4B5563"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUGGESTED ACTION"
                            android:textColor="#6B7280"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginTop="12dp" />

                        <TextView
                            android:id="@+id/suggestedActionText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Assess patient comfort\n• Check for secretions\n• Verify trigger sensitivity"
                            android:textColor="#4B5563"
                            android:lineSpacingExtra="4dp"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/viewFullAiDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View Full AI Details →"
                        android:textColor="#8B5CF6"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:padding="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:layout_alignParentBottom="true">

        <Button
            android:id="@+id/acknowledgeButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Acknowledge Alert"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="#007BFF"
            app:cornerRadius="8dp" />

        <Button
            android:id="@+id/escalateButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Escalate to Physician"
            android:textAllCaps="false"
            android:textColor="#007BFF"
            app:strokeColor="#007BFF"
            app:cornerRadius="8dp" />

    </LinearLayout>

</RelativeLayout>

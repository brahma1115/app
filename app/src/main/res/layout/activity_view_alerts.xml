                            android:layout_height="wrap_content"
                            android:text="15m ago"
                            android:layout_alignParentEnd="true"
                            android:textColor="#757575"/>
                        <TextView
                            android:id="@+id/patientDetails2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Priya Sharma • ICU-02"
                            android:layout_below="@id/alertTitle2"
                            android:layout_marginTop="4dp"
                            android:textColor="#616161"/>
                        <TextView
                            android:id="@+id/status2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Warning"
                            android:textColor="#FFC107"
                            android:background="@drawable/status_warning_background"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_below="@id/patientDetails2"
                            android:layout_marginTop="16dp"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Details →"
                            android:textColor="#007BFF"
                            android:layout_alignBottom="@id/status2"
                            android:layout_alignParentEnd="true"
                            android:textStyle="bold"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Alert Card 3: Sneha Reddy (Critical) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/alertCard3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"

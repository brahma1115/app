                            android:layout_alignParentEnd="true"
                            android:textColor="#757575"/>
                        <TextView
                            android:id="@+id/patientDetails4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vikram Singh • ICU-05"
                            android:layout_below="@id/alertTitle4"
                            android:layout_marginTop="4dp"
                            android:textColor="#616161"/>
                        <TextView
                            android:id="@+id/status4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Warning"
                            android:textColor="#FFC107"
                            android:background="@drawable/status_warning_background"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_below="@id/patientDetails4"
                            android:layout_marginTop="16dp"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Details →"
                            android:textColor="#007BFF"
                            android:layout_alignBottom="@id/status4"
                            android:layout_alignParentEnd="true"
                            android:textStyle="bold"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Alert Card 5: Anjali Gupta (Critical) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/alertCard5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:tag="Critical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="6dp"
                        android:layout_height="match_parent"
                        android:minHeight="120dp"
                        android:background="#DC3545"/>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/alertTitle5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Low Pulse"
                            android:textStyle="bold"
                            android:textColor="@android:color/black"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1h ago"
                            android:layout_alignParentEnd="true"
                            android:textColor="#757575"/>
                        <TextView
                            android:id="@+id/patientDetails5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Anjali Gupta • ICU-06"
                            android:layout_below="@id/alertTitle5"
                            android:layout_marginTop="4dp"
                            android:textColor="#616161"/>
                        <TextView
                            android:id="@+id/status5"
                            android:layout_width="wrap_content"

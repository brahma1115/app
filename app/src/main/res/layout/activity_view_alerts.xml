                            android:layout_below="@id/alertTitle3"
                            android:layout_marginTop="4dp"
                            android:textColor="#616161"/>
                        <TextView
                            android:id="@+id/status3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Critical"
                            android:textColor="#DC3545"
                            android:background="@drawable/status_critical_background"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_below="@id/patientDetails3"
                            android:layout_marginTop="16dp"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Details →"
                            android:textColor="#007BFF"
                            android:layout_alignBottom="@id/status3"
                            android:layout_alignParentEnd="true"
                            android:textStyle="bold"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Alert Card 4: Vikram Singh (Warning) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/alertCard4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".ViewAlertsActivity">

    <!-- Header / Filter Buttons -->
    <LinearLayout
        android:id="@+id/filterHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#F0F4FF">

        <Button
            android:id="@+id/allButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="All"
            android:textAllCaps="false"
            android:background="@drawable/filter_button_selected_background"
            android:textColor="@android:color/white"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/criticalButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Critical"
            android:textAllCaps="false"
            android:background="@drawable/filter_button_unselected_background"
            android:textColor="@android:color/black"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/warningButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Warning"
            android:textAllCaps="false"
            android:background="@drawable/filter_button_unselected_background"
            android:textColor="@android:color/black" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/filterHeader">

        <LinearLayout
            android:id="@+id/alertsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Alert Card 1: Rajesh Kumar (Critical) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/alertCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:tag="Critical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="6dp"
                        android:layout_height="match_parent"
                        android:minHeight="120dp"
                        android:background="#DC3545"/>
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/alertTitle1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="High Pressure"
                            android:textStyle="bold"
                            android:textColor="@android:color/black"
                            android:textSize="16sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2m ago"
                            android:layout_alignParentEnd="true"
                            android:textColor="#757575"/>
                        <TextView
                            android:id="@+id/patientDetails1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rajesh Kumar • ICU-01"
                            android:layout_below="@id/alertTitle1"
                            android:layout_marginTop="4dp"
                            android:textColor="#616161"/>
                        <TextView
                            android:id="@+id/status1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● Critical"
                            android:textColor="#DC3545"
                            android:background="@drawable/status_critical_background"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_below="@id/patientDetails1"
                            android:layout_marginTop="16dp"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Details →"
                            android:textColor="#007BFF"
                            android:layout_alignBottom="@id/status1"
                            android:layout_alignParentEnd="true"
                            android:textStyle="bold"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Alert Card 2: Priya Sharma (Warning) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/alertCard2"
                android:layout_width="match_parent"
